# Cantor Brain 环境配置

# ============ 应用配置 ============
DEBUG=false
PROJECT_NAME=Cantor Brain
VERSION=1.0.0

# ============ 数据库配置 ============
# 本地开发环境
DATABASE_URL=postgresql+asyncpg://cantor:cantor_secret@localhost:5432/cantor

# ============ Redis 配置 ============
# 本地开发环境（无密码）
REDIS_URL=redis://localhost:6379/0

# ============ JWT 配置 ============
# ⚠️ 生产环境必须修改此密钥
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ 密码策略 ============
PASSWORD_MIN_LENGTH=12
PASSWORD_HASH_COST=12
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ============ API Key ============
API_KEY_PREFIX=cantor_
API_KEY_LENGTH=48

# ============ CORS ============
# 本地开发允许所有来源
CORS_ORIGINS=*

# ============ Docker 环境说明 ============
# 如果在 Docker 环境中运行，使用以下配置：
# DATABASE_URL=postgresql+asyncpg://cantor:cantor_secret@postgres:5432/cantor
# REDIS_URL=redis://:redis_secret@redis:6379/0
