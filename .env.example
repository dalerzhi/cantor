# Cantor 环境配置

# 数据库配置
POSTGRES_USER=cantor
POSTGRES_PASSWORD=cantor_secret
POSTGRES_DB=cantor
POSTGRES_PORT=5432

# Redis 配置
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# JWT 配置
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 密码策略
PASSWORD_MIN_LENGTH=12
PASSWORD_HASH_COST=12
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# API Key 配置
API_KEY_PREFIX=cantor_
API_KEY_LENGTH=48

# IaaS 配置 (CAStack 云平台)
IAAS_BASE_URL=https://castack-gncenter.cheersucloud.com/openapi
IAAS_ACCESS_KEY=91e28b4734d642b29c1ad64cbb44df8a
IAAS_SECRET_KEY=a589615d6d144dd5aa3e776a9ac4f303

# 服务端口
BRAIN_PORT=8000
GATEWAY_PORT=8766
FRONTEND_PORT=3000

# CORS
CORS_ORIGINS=*
